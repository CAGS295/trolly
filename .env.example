# Global book integration tests (optional live Binance REST).
#
# Default `cargo test` runs offline fixture tests only. Live network is gated by
# `#[ignore]` on `global_book_live_rest_merge` plus `RUN_GLOBAL_BOOK_INTEGRATION`.
#
# Enable the live test:
#   1. cp .env.example .env
#   2. Set RUN_GLOBAL_BOOK_INTEGRATION=1 in `.env` (or export it for one run)
#   3. cargo test --test global_book global_book_live_rest_merge -- --ignored --nocapture
#
# Optional: change the symbol (default BTCUSDT).
# TROLLY_INTEGRATION_SYMBOL=ETHUSDT

RUN_GLOBAL_BOOK_INTEGRATION=0
TROLLY_INTEGRATION_SYMBOL=BTCUSDT
