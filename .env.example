# Live global-book integration test (optional; default `cargo test` stays offline).
#
# 1. Copy this file to `.env` in the repo root:
#      cp .env.example .env
# 2. Enable the live REST merge test:
#      RUN_GLOBAL_BOOK_INTEGRATION=1
# 3. Run only the ignored live test (requires outbound HTTPS to Binance):
#      cargo test --test global_book global_book_live_rest_merge -- --ignored
#
# Fixture tests in `tests/global_book.rs` always run with plain `cargo test --test global_book`
# (no network). The live test is `#[ignore]` unless you pass `--ignored` and set the flag below.
#
# Same template as `.env.sample` — keep both in sync when editing.

RUN_GLOBAL_BOOK_INTEGRATION=0
TROLLY_INTEGRATION_SYMBOL=BTCUSDT

# Binance demo / testnet (WP-017; optional). Secret required for signed spot user-data
# WebSocket API subscribe (`userDataStream.subscribe.signature`) and future signed order APIs.
#
# 1. Copy this file to `.env` in the repo root:
#      cp .env.example .env
# 2. Set demo credentials and enable integration tests:
#      RUN_BINANCE_DEMO_INTEGRATION=1
#      DEMO_BINANCE_KEY=...
#      DEMO_BINANCE_SECRET=...
# 3. Run ignored demo tests (requires outbound HTTPS/WSS to Binance demo hosts):
#      cargo test --test binance_demo -- --ignored
#
# Optional symbol override (default BTCUSDT):
#      TROLLY_DEMO_SYMBOL=BTCUSDT
#
# Default `cargo test --workspace` stays offline; demo tests skip when the flag is unset or keys
# are missing. Never use production API keys.

RUN_BINANCE_DEMO_INTEGRATION=0
TROLLY_DEMO_SYMBOL=BTCUSDT
DEMO_BINANCE_KEY=
DEMO_BINANCE_SECRET=