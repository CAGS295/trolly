# Live global-book integration test (optional; default `cargo test` stays offline).
#
# 1. Copy this file to `.env` in the repo root:
#      cp .env.example .env
# 2. Enable the live REST merge test:
#      RUN_GLOBAL_BOOK_INTEGRATION=1
# 3. Run only the ignored live test (requires outbound HTTPS to Binance):
#      cargo test --test global_book global_book_live_rest_merge -- --ignored
#
# Fixture tests in `tests/global_book.rs` always run with plain `cargo test --test global_book`
# (no network). The live test is `#[ignore]` unless you pass `--ignored` and set the flag below.

RUN_GLOBAL_BOOK_INTEGRATION=0
TROLLY_INTEGRATION_SYMBOL=BTCUSDT

# Binance demo / testnet integration (WP-017; optional). Use demo keys only — never production.
#
# 1. `cp .env.example .env`
# 2. Set `RUN_BINANCE_DEMO_INTEGRATION=1` and fill `DEMO_BINANCE_KEY` / `DEMO_BINANCE_SECRET`
# 3. Run ignored demo tests (spot + USDM authenticated streams):
#      cargo test --test binance_demo_integration -- --ignored
#
# Demo endpoints: spot REST `https://demo-api.binance.com/api`, spot WS API
# `wss://demo-ws-api.binance.com/ws-api/v3`, USDM REST `https://demo-fapi.binance.com`,
# USDM private WS `wss://fstream.binancefuture.com/private/ws/<listenKey>`.
# See `tests/binance_demo_integration.rs` and crate READMEs for details.

RUN_BINANCE_DEMO_INTEGRATION=0
TROLLY_DEMO_SYMBOL=BTCUSDT
DEMO_BINANCE_KEY=
DEMO_BINANCE_SECRET=
