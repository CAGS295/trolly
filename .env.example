# Integration test environment (optional)
#
# Live tests are OFF by default. Fixture tests in `tests/global_book.rs` always run
# with plain `cargo test` and never hit the network.
#
# To run the live Binance REST merge test:
#   1. cp .env.example .env
#   2. Set RUN_GLOBAL_BOOK_INTEGRATION=1 in `.env` (or export it in your shell)
#   3. cargo test --test global_book global_book_live_rest_merge -- --ignored --nocapture
#
# Optional: override the symbol used by the live test (default: BTCUSDT).

RUN_GLOBAL_BOOK_INTEGRATION=0
TROLLY_INTEGRATION_SYMBOL=BTCUSDT
