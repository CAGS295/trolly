# Copy this file to `.env` in the repo root for opt-in integration tests.
# `.env` is gitignored; never commit secrets here.
#
# --- Global book live REST merge ---
#
# 1. cp .env.example .env
# 2. Set RUN_GLOBAL_BOOK_INTEGRATION=1 below
# 3. cargo test --test global_book global_book_live_rest_merge -- --ignored --nocapture
#
# Default `cargo test` skips this test (`#[ignore]`). Fixture tests in
# tests/global_book.rs always run with no network and no `.env`.
#
# When Binance REST is geo-blocked (HTTP 451), the live test automatically uses a
# loopback REST stub so fetch → parse → merge is still verified. Force the stub:
#   TROLLY_INTEGRATION_USE_LOCAL_REST=1
#
# Override REST URLs (e.g. custom proxy or mock):
#   TROLLY_INTEGRATION_SPOT_REST_URL=http://127.0.0.1:8080/api/v3/depth?symbol=BTCUSDT&limit=5000
#   TROLLY_INTEGRATION_USDM_REST_URL=http://127.0.0.1:8080/fapi/v1/depth?symbol=BTCUSDT&limit=1000

RUN_GLOBAL_BOOK_INTEGRATION=0
TROLLY_INTEGRATION_SYMBOL=BTCUSDT
# TROLLY_INTEGRATION_USE_LOCAL_REST=0
# TROLLY_INTEGRATION_SPOT_REST_URL=
# TROLLY_INTEGRATION_USDM_REST_URL=
