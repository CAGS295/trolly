# Copy to `.env` in the repo root for opt-in integration tests:
#   cp .env.example .env
#
# Enable the live global-book REST merge test (Binance spot + USDM, no WebSocket):
#   1. Set RUN_GLOBAL_BOOK_INTEGRATION=1 below (or export in your shell)
#   2. cargo test --test global_book global_book_live_rest_merge -- --ignored
#
# Default `cargo test` skips this test; fixture tests in tests/global_book.rs always run.
# See README.md "Testing" section for the full flow.

RUN_GLOBAL_BOOK_INTEGRATION=0
TROLLY_INTEGRATION_SYMBOL=BTCUSDT
