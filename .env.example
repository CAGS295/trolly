# Live integration tests (optional; default `cargo test --workspace` stays offline).
#
# 1. Copy this file to `.env` in the repo root:
#      cp .env.example .env
# 2. Enable the tests you want (see sections below).
# 3. Run only the ignored live tests with `-- --ignored`.
#
# Fixture tests always run with plain `cargo test --workspace` (no network). Live tests
# are `#[ignore]` unless you pass `--ignored` and set the respective flag below.

# ── Global book live REST merge (tests/global_book.rs) ──────────────────────
# Requires outbound HTTPS to Binance spot + USDM REST.
#   cargo test --test global_book global_book_live_rest_merge -- --ignored
RUN_GLOBAL_BOOK_INTEGRATION=0
TROLLY_INTEGRATION_SYMBOL=BTCUSDT

# ── Binance demo/testnet integration (tests/binance_demo.rs) ────────────────
# Binance demo trading uses your real Binance credentials but operates against
# simulated funds.  Credentials are required for signed user-data subscribe and
# listenKey lifecycle tests.  The REST depth snapshot tests are public (no keys).
#
# Demo base URLs (for reference; see tests/binance_demo.rs):
#   Spot  REST  : https://demo-api.binance.com/api/v3
#   Spot  WS API: wss://demo-ws-api.binance.com:443/ws-api/v3
#   Spot  stream: wss://demo-stream.binance.com:9443/ws
#   USDM  REST  : https://demo-fapi.binance.com/fapi/v1
#   USDM  stream: wss://fstream.binance.com/ws (listenKey from demo-fapi)
#
# Enable the opt-in demo tests:
#   cargo test --test binance_demo -- --ignored
RUN_BINANCE_DEMO_INTEGRATION=0
TROLLY_DEMO_SYMBOL=BTCUSDT

# API credentials for signed endpoints (spot WS API subscribe, USDM listenKey).
# Leave blank to run only the public REST depth snapshot tests.
DEMO_BINANCE_KEY=
DEMO_BINANCE_SECRET=