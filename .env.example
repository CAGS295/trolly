# Copy this file to `.env` in the repo root to configure integration tests.
#
# Quick-start:
#   cp .env.example .env
#   # edit .env — set RUN_GLOBAL_BOOK_INTEGRATION=1 to enable live network tests
#   cargo test --test global_book global_book_live_rest_merge -- --ignored --nocapture
#
# The live test hits Binance REST (spot + USDM futures) and merges the books.
# It is skipped by default so `cargo test` never requires network access.

# Set to 1 (or "true") to enable the live Binance REST integration test.
RUN_GLOBAL_BOOK_INTEGRATION=0

# Symbol used by the live integration test (default: BTCUSDT).
TROLLY_INTEGRATION_SYMBOL=BTCUSDT
