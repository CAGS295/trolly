# Integration test configuration (repo root)
#
# Quick start — live global-book REST merge test:
#   1. cp .env.example .env
#   2. Set RUN_GLOBAL_BOOK_INTEGRATION=1 in .env
#   3. cargo test --test global_book global_book_live_rest_merge -- --ignored --nocapture
#
# Default `cargo test` skips the live test (#[ignore]); fixture tests in
# tests/global_book.rs always run with no network access.
#
# You can also enable inline without a .env file:
#   RUN_GLOBAL_BOOK_INTEGRATION=1 cargo test --test global_book global_book_live_rest_merge -- --ignored --nocapture

RUN_GLOBAL_BOOK_INTEGRATION=0
TROLLY_INTEGRATION_SYMBOL=BTCUSDT
